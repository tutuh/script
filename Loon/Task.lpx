[Script]
cron "10 5 0 * * *" script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/sfexpress/sfexpress.js, timeout=120, tag=顺丰速运_签到

cron "20 15,10 0 * * *" script-path=https://raw.githubusercontent.com/NobyDa/Script/master/BDTieBa-DailyBonus/TieBa.js, timeout=120, tag=百度贴吧_签到

cron "10 20 0 * * *" script-path=https://raw.githubusercontent.com/Sliverkiss/GoodNight/master/Script/tuhu.js, timeout=60, tag=途虎_签到

 

#!name= 获取Cookie订阅
#!desc=自用，收集自各大佬脚本，该订阅仅适用于定时签到脚本的Cookie获取.可以在使用后手动将其禁用，以免产生不必要的MITM

[MITM]
hostname = %APPEND% api.club.lenovo.cn, auto.chediandian.com, app.relxtech.com, api.tuhu.cn, passport.biligame.com, ms.jr.jd.com, me-api.jd.com, api.m.jd.com, www.52pojie.cn, h5.ele.me, maicai.api.ddxq.mobi, apph5.manmanbuy.com, c.tieba.baidu.com, zhiyou.smzdm.com, mobwsa.ximalaya.com, ccsp-egmas.sf-express.com, user.qunar.com, i.meituan.com, *.feng.com, *.bilibili.com, operation-api.jimistore.com, act.10010.com, m.client.10010.com, credits.bz.mgtv.com

# 联想智选 api.club.lenovo.cn
https:\/\/api\.club\.lenovo\.cn\/common\/signin\/add url script-request-body https://raw.githubusercontent.com/tutuh/script/master/task/lenovo/lenovo.js
# 微信小程序"太平洋车生活" auto.chediandian.com
https:\/\/auto\.chediandian\.com\/activity\/tb-sign\/sign-handle url script-request-body https://raw.githubusercontent.com/tutuh/script/master/task/cpic/cpic.js
# 悦刻app app.relxtech.com
https:\/\/app\.relxtech\.com\/dianziyan-api\/api\/v3\/community\/check-in url script-request-header https://raw.githubusercontent.com/tutuh/script/master/task/relx/relx.js
# 途虎养车 api.tuhu.cn
https:\/\/api\.tuhu\.cn\/User\/UserCheckInVersion1 url script-request-header https://raw.githubusercontent.com/tutuh/script/master/task/tuhu/tuhu.js

# --- by  NobyDa ---
# 哔哩哔哩漫画cookie  passport.biligame.com
Bili漫画Cookie = type=http-request,pattern=^https:\/\/passport\.biligame\.com\/api\/login\/sso.+?version%22%3A%22(3|4|5),script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Bilibili-DailyBonus/Manga.js
# 京东多合一ms.jr.jd.com, me-api.jd.com, api.m.jd.com
#Safari浏览器登录 https://home.m.jd.com/myJd/newhome.action 点击签到并且出现签到日历后
# 获取京东Cookie. 
获取京东Cookie = type=http-request,requires-body=1,pattern=^https:\/\/(api\.m|me-api|ms\.jr)\.jd\.com\/(client\.action\?functionId=signBean|user_new\/info\/GetJDUserInfoUnion\?|gw\/generic\/hy\/h5\/m\/appSign\?),script-path=https://raw.githubusercontent.com/NobyDa/Script/master/JD-DailyBonus/JD_DailyBonus.js
# 吾爱破解签到cookie www.52pojie.cn
吾爱获取Cookie = type=http-request,pattern=https:\/\/www\.52pojie\.cn\/home\.php\?,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/52pojie-DailyBonus/52pojie.js
# 爱奇艺会员签到cookie ifac*.iqiyi.com
爱奇艺获取Cookie = type=http-request,pattern=^https?:\/\/iface(\d)?\.iqiyi\.com\/,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/iQIYI-DailyBonus/iQIYI.js

# --- by songyangzz ---

#!name=网络解锁检测
#!desc=ChatGPT, Gemini, Netflix, Disney+, YouTube 解锁检测
#!category=Panel
#!arguments=更新频率:-1, 请求超时:30, 面板名称:网络解锁检测, Icon:play.tv.fill, Color:E83A5C, ALIGN_MODE:monospace
#!arguments-desc=[参数说明]\n\n更新频率: 面板刷新频率（默认手动刷新）。\n\n请求超时: 单位：秒，默认 30 秒。\n\n面板名称: 自定义面板标题。\n\nALIGN_MODE:字体格式，默认：monospace，可选：native

[Panel]
网络解锁检测 = script-name=解锁检测,update-interval={{{更新频率}}}

[Script]
解锁检测 = type=generic,timeout={{{请求超时}}},script-path=https://raw.githubusercontent.com/tutuh/script/master/Surge/Panel/JS/Stream.js,argument=title={{{面板名称}}}&icon={{{Icon}}}&color=#{{{Color}}}&ALIGN_MODE={{{ALIGN_MODE}}} 

#!name=每日签到
#!desc=自动签到脚本
#!arguments=顺丰签到:20 10 0 * * *,贴吧签到:20 15 0 * * *,途虎签到:30 30 0 * * *,Boxjs备份定时:10 8 1 */3 * *,Boxjs恢复定时:30 10 5 * * *,Boxjs会话切换定时:30 10 5 * * *,Boxjs备份:Boxjs数据备份,Boxjs恢复:Boxjs数据恢复,Boxjs会话切换:Boxjs会话切换
#!arguments-desc=定时签到：Cron表达式，秒 分 时 * * * \n\nBoxjs备份：输入 # 表示禁用。\n\nBoxjs恢复：输入 # 表示禁用。\n\nBoxjs会话切换：输入 # 表示禁用。
#!category=签到模块

[Script]
顺丰速运_签到 = type=cron,cronexp="{{{顺丰签到}}}",wake-system=1,timeout=120,script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/sfexpress/sfexpress.js

百度贴吧_签到 = type=cron,cronexp="{{{贴吧签到}}}",wake-system=1,timeout=120,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/BDTieBa-DailyBonus/TieBa.js

途虎_签到 = type=cron,cronexp="{{{途虎签到}}}",wake-system=1,timeout=60,script-path=https://raw.githubusercontent.com/Sliverkiss/GoodNight/master/Script/tuhu.js

{{{Boxjs备份}}}  = type=cron,cronexp="{{{Boxjs备份定时}}}",wake-system=1,timeout=180,script-path=https://raw.githubusercontent.com/dompling/Script/master/gist/backup.js

{{{Boxjs恢复}}} = type=cron,cronexp="{{{Boxjs恢复定时}}}",wake-system=1,timeout=120,script-path=https://raw.githubusercontent.com/dompling/Script/master/gist/restore.js

{{{Boxjs会话切换}}} = type=cron,cronexp="{{{Boxjs会话切换定时}}}",wake-system=1,timeout=20,script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/box/switcher/box.switcher.js
